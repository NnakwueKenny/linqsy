{
  "name": "@linqsy/config",
  "version": "0.1.1",
  "type": "module",
  "description": "Configuration and app metadata for Linqsy.",
  "license": "MIT",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": "./dist/index.js"
  },
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json && node ../../scripts/rewrite-relative-imports.mjs dist",
    "prepack": "pnpm build",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "zod": "^4.3.6"
  }
}
